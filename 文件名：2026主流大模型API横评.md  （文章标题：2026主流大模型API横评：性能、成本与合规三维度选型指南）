class ModelCostOptimizer:
    """
    模型成本优化器
    
    根据任务类型自动选择性价比最高的模型
    """
    
    # 模型配置：能力等级 → 推荐模型 + 性价比评分
    MODEL_PROFILES = {
        "code_generation": [
            ("deepseek-v4", 9.5, 1.2),    # 名称、能力强(10分)、价格($/百万)
            ("gpt-5.4", 9.8, 15.0),
            ("claude-sonnet-4-6", 9.5, 12.0),
        ],
        "fast_response": [
            ("claude-4-haiku", 8.0, 0.08),
            ("gemini-3-flash-preview", 8.5, 0.10),
            ("gpt-5.4-mini", 8.5, 0.15),
        ],
        "long_context": [
            ("gemini-3-pro", 9.5, 10.0),     # 1M上下文
            ("claude-sonnet-4-6", 9.5, 12.0),  # 200K上下文
            ("doubao-seed-2.0-pro", 9.0, 2.0),  # 256K上下文
        ],
        "chinese_content": [
            ("qwen3.5", 9.0, 0.80),
            ("deepseek-v4", 8.8, 1.20),
            ("doubao-seed-2.0-pro", 9.0, 2.0),
        ]
    }
    
    def select_model(self, task_type: str, max_cost: float = None) -> str:
        """根据任务类型选择最佳模型"""
        candidates = self.MODEL_PROFILES.get(task_type, self.MODEL_PROFILES["fast_response"])
        
        # 按性价比排序
        sorted_candidates = sorted(
            candidates, 
            key=lambda x: x[1]/x[2],  # 能力/价格 = 性价比
            reverse=True
        )
        
        for model, ability, price in sorted_candidates:
            if max_cost and price > max_cost:
                continue
            return model
        
        return sorted_candidates[0][0]

