# GLM-5.2 三通道路由器环境变量样例
# 复制本文件为 .env 后填入真实凭据；.env 已在 .gitignore 中，不会被提交

# 智谱开放平台 API Key
# 申请入口：https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=

# 国家超算互联网 API Key
# 申请入口（以控制台为准）：https://www.scnet.cn/
SCNET_API_KEY=

# 自部署 vLLM / SGLang 后端
SELFHOST_BASE_URL=http://your-vllm-server:8000/v1
SELFHOST_API_KEY=

# 路由器选配
# 可选值：profile_realtime / profile_batch / profile_longctx
ROUTER_PROFILE=profile_realtime
